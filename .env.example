# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI OAuth (for Codex access)
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# API Server
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false

# Valid API Keys (comma-separated)
VALID_API_KEYS=key1,key2,key3

# Database
DB_PATH=tasks/tasks.json
METRICS_DB_PATH=tasks/metrics.json

# System Limits
MAX_CONCURRENT_TASKS=5
MAX_RAM_USAGE=0.85
MAX_CPU_USAGE=0.80
MAX_DISK_TEMP=85

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs/system.log

# Feature Flags
ENABLE_LEARNING=true
ENABLE_PLAYBOOKS=true
ENABLE_OPTIMIZATION=true
